{
  "name": "humorhub",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "last 2 versions",
    "not dead",
    "fully supports es6-module"
  ],
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview": "npm run format && npm run build && next start"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vis.gl/react-google-maps": "^1.8.3",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "eslint --fix",
    "*.{json,css,md,mdx,html}": "prettier --write"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "@firebase/util@1.15.1": true,
    "protobufjs@7.6.2": true,
    "sharp@0.34.5": true
  }
}
